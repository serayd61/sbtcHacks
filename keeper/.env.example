# Keeper Bot Environment Variables
#
# Copy to .env and fill in values:
#   cp .env.example .env

# Stacks wallet private key (hex, 64 chars)
# This wallet must be authorized as oracle submitter and have STX for gas
# Without this, keeper runs in dry-run mode (observation only)
KEEPER_PRIVATE_KEY=

# Keeper wallet Stacks address (for balance monitoring)
# If not set, uses deployer address
KEEPER_ADDRESS=

# Discord/Telegram webhook URL for alerts
# Discord: https://discord.com/api/webhooks/...
# Telegram: https://api.telegram.org/bot<token>/sendMessage?chat_id=<id>
KEEPER_WEBHOOK_URL=
