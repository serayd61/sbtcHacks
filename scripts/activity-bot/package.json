{
  "name": "sbtc-activity-bot",
  "version": "1.0.0",
  "description": "Activity bot for sBTC Options Vault - generates wallets, distributes STX, calls faucet, buys options",
  "type": "module",
  "private": true,
  "scripts": {
    "generate": "tsx index.ts --step generate",
    "distribute": "tsx index.ts --step distribute",
    "faucet": "tsx index.ts --step faucet",
    "buy": "tsx index.ts --step buy",
    "all": "tsx index.ts --step all",
    "daily": "tsx daily-runner.ts",
    "create-listings": "tsx create-listings.ts",
    "gov:init": "tsx governance-bot.ts --step init",
    "gov:distribute": "tsx governance-bot.ts --step distribute",
    "gov:propose": "tsx governance-bot.ts --step propose",
    "gov:vote": "tsx governance-bot.ts --step vote",
    "gov:execute": "tsx governance-bot.ts --step execute",
    "gov:daily": "tsx governance-bot.ts --step daily",
    "gov:status": "tsx governance-bot.ts --step status"
  },
  "dependencies": {
    "@scure/bip39": "^1.2.0",
    "@stacks/network": "^7.0.0",
    "@stacks/transactions": "^7.2.0",
    "@stacks/wallet-sdk": "^7.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.0.0"
  }
}
